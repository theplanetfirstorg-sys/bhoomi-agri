# Database
DATABASE_URL=postgresql://user:password@localhost:5432/bhoomi_agri

# JWT
JWT_SECRET=your-jwt-secret-base64-64-chars
JWT_REFRESH_SECRET=your-refresh-secret-base64-64-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Claude AI
ANTHROPIC_API_KEY=sk-ant-...

# Google Maps
GOOGLE_MAPS_API_KEY=AIza...

# OpenWeatherMap
OPENWEATHERMAP_API_KEY=...

# AWS S3
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=ap-south-1
AWS_S3_BUCKET_NAME=bhoomi-agri-uploads

# Firebase Cloud Messaging
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Email (choose one)
RESEND_API_KEY=re_...
# SENDGRID_API_KEY=SG....

# App
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174

# MQTT (v2 - disabled in v1)
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_ENABLED=false
